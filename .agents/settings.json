{
  "antigravity.security.reviewPolicy": "proceed-in-sandbox",
  "enableTerminalSandbox": true,
  "antigravity.security.strictMode": false,
  "permissions": {
    "allow": [
      "command(*)",
      "function(*)"
    ],
    "ask": [],
    "deny": [
      "command(dd *)",
      "command(dd)",
      "command(git push *)",
      "command(git push)"
    ]
  },
  "sandbox.trustedBinaries": [
    "nasm",
    "make",
    "dos_port/tools/work_queue",
    "dos_port/tools/build_index"
  ]
}
