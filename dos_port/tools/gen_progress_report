#!/usr/bin/env python3
"""
gen_progress_report — Render a human-readable translation-progress snapshot from the
work queue to docs/translation_progress.md.

Read-only. The DB stays the source of truth; this is the committable markdown view.
It shells out to `work_queue` (JSON) rather than touching translation.db directly, so
it never bypasses the audit/migration path (see the work_queue header).

Usage:
    dos_port/tools/gen_progress_report            # write docs/translation_progress.md
    dos_port/tools/gen_progress_report --stdout   # print to stdout instead
"""

import argparse
import json
import os
import subprocess
import sys
from datetime import datetime, timezone

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
REPO_ROOT  = os.path.normpath(os.path.join(SCRIPT_DIR, '..', '..'))
WORK_QUEUE = os.path.join(SCRIPT_DIR, 'work_queue')
OUT_PATH   = os.path.join(REPO_ROOT, 'docs', 'translation_progress.md')

# Column order for status tables (only columns with data are shown).
STATUS_ORDER = ['needs_translation', 'in_progress', 'translated', 'wired',
                'verified', 'skip', 'complete', 'unverified']


def wq(*args):
    """Run a work_queue subcommand and parse its JSON output."""
    res = subprocess.run([sys.executable, WORK_QUEUE, *args],
                         capture_output=True, text=True)
    if res.returncode != 0:
        sys.stderr.write(res.stderr or res.stdout)
        sys.exit(f'work_queue {" ".join(args)} failed')
    return json.loads(res.stdout)


def md_table(headers, rows):
    out = ['| ' + ' | '.join(headers) + ' |',
           '| ' + ' | '.join('---' for _ in headers) + ' |']
    for r in rows:
        out.append('| ' + ' | '.join(str(c) for c in r) + ' |')
    return '\n'.join(out)


def build_report():
    status   = wq('status')
    summary  = status['summary']          # {category: {status: n}}
    allfns   = wq('list')['functions']    # every function row
    stubs    = wq('stub', 'list')['stubs']

    # Which status columns actually appear, in canonical order.
    present = [s for s in STATUS_ORDER
               if any(s in cats for cats in summary.values())]

    lines = ['# Translation Progress', '',
             '_Generated by `dos_port/tools/gen_progress_report` from '
             '`translation.db`. Do not hand-edit._', '',
             f'_Last generated: {datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")}_',
             '']

    # ── Summary by category ──────────────────────────────────────────────────
    lines += ['## Summary', '']
    rows = []
    for cat in sorted(summary):
        counts = summary[cat]
        total = sum(counts.values())
        rows.append([cat] + [counts.get(s, 0) for s in present] + [total])
    # totals row
    tot = status['totals']
    rows.append(['**all**'] + [sum(summary[c].get(s, 0) for c in summary) for s in present]
                + [sum(tot.values())])
    lines += [md_table(['category'] + present + ['total'], rows), '']

    # ── Per-map script translation ───────────────────────────────────────────
    scripts = [f for f in allfns if f['category'] == 'script']
    lines += ['## Script translation (per map)', '']
    if not scripts:
        lines += ['_No `script`-category rows yet. Run `build_index` to index '
                  '`scripts/`._', '']
    else:
        by_map = {}
        for f in scripts:
            by_map.setdefault(f['source_file'], {}).setdefault(f['status'], 0)
            by_map[f['source_file']][f['status']] += 1
        sp_present = [s for s in STATUS_ORDER if any(s in m for m in by_map.values())]
        rows = []
        for src in sorted(by_map):
            counts = by_map[src]
            done = counts.get('verified', 0) + counts.get('wired', 0) \
                + counts.get('translated', 0) + counts.get('complete', 0)
            total = sum(counts.values())
            name = src[len('scripts/'):] if src.startswith('scripts/') else src
            rows.append([name, f'{done}/{total}']
                        + [counts.get(s, 0) for s in sp_present])
        lines += [md_table(['map', 'done'] + sp_present, rows), '']

    # ── Outstanding stubs by kind ────────────────────────────────────────────
    lines += ['## Outstanding stubs', '']
    unresolved = [s for s in stubs if not s['resolved']]
    if not unresolved:
        lines += ['_None recorded._', '']
    else:
        by_kind = {}
        for s in unresolved:
            by_kind.setdefault(s['kind'], []).append(s)
        for kind in sorted(by_kind):
            items = by_kind[kind]
            lines += [f'### {kind} ({len(items)})', '']
            for s in sorted(items, key=lambda x: x['name']):
                where = s.get('source_file') or ''
                note = f" — {s['notes']}" if s.get('notes') else ''
                lines.append(f"- `{s['name']}` ({where}){note}")
            lines.append('')

    return '\n'.join(lines).rstrip() + '\n'


def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument('--stdout', action='store_true', help='print instead of writing file')
    args = ap.parse_args()

    report = build_report()
    if args.stdout:
        sys.stdout.write(report)
    else:
        os.makedirs(os.path.dirname(OUT_PATH), exist_ok=True)
        with open(OUT_PATH, 'w', encoding='utf-8') as fh:
            fh.write(report)
        print(f'Wrote {os.path.relpath(OUT_PATH, REPO_ROOT)}')


if __name__ == '__main__':
    main()
