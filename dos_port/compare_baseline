#!/usr/bin/env python3

with open("FRAME_BASELINE.BIN", "rb") as f:
    b = f.read()
with open("FRAME.BIN", "rb") as f:
    s = f.read()

best_dy = 0
best_match = 0
for dy in range(-16, 16):
    match = 0
    total = 0
    for y in range(40, 160):
        for x in range(40, 280):
            if 140 <= x <= 180 and 80 <= y <= 120:
                continue
            if s[y*320 + x] == b[(y+dy)*320 + x]:
                match += 1
            total += 1
    if match > best_match:
        best_match = match
        best_dy = dy

print(f"Best match at dy={best_dy}: {best_match/total*100:.2f}%")
